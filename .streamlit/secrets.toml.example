# Reference only -- not something you need to fill in and save locally.
#
# Local dev: don't use this file at all. Set env vars instead and auth via
# your own gcloud session -- no key file, no secrets.toml, nothing in this
# repo:
#     export VA_CF_PROJECT_ID='your-gcp-project-id'
#     gcloud auth application-default login
#     streamlit run app.py
#
# Deploying to Streamlit Community Cloud: paste the lines below into that
# app's own Settings -> Secrets panel on share.streamlit.io -- never into a
# file here. That's Streamlit's servers, not this repo; the key never
# touches git or your local disk once you do this.

project_id = "your-gcp-project-id"
gold_dataset = "virginia_elections_gold"
last_updated = "2026-07-01"

# Read-only service account, scoped to ONLY the gold dataset (see
# "Deploying" in README.md for the exact gcloud/bq commands that create this
# account with the minimum permissions). Copy these field names straight out
# of the JSON key file gcloud gives you -- same names, same values.
[gcp_service_account]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "va-cf-readonly@your-gcp-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
