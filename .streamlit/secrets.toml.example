# Copy to .streamlit/secrets.toml (gitignored) and fill in real values.
# Locally: streamlit run app.py picks this up automatically.
# On Streamlit Community Cloud: paste the same keys into the app's Secrets settings.

project_id = "your-gcp-project-id"
gold_dataset = "virginia_elections_gold"
last_updated = "2026-07-01"

# Service account key for a read-only account scoped to the gold dataset only
# (BigQuery Data Viewer + Job User on virginia_elections_gold, nothing else).
# Paste the contents of the downloaded JSON key file's fields below.
[gcp_service_account]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "va-cf-readonly@your-gcp-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
